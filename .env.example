# jaccount 登录凭据
JACCOUNT_USER=your_jaccount_id
JACCOUNT_PASS=your_password

# course.sjtu.plus(选课社区)登录凭据 —— 该站账号体系与 jaccount 无关联,密码是
# 你在 course.sjtu.plus 站内单独设置的密码,不是上面的 jaccount 密码。
# 邮箱默认按 {JACCOUNT_USER}@sjtu.edu.cn 自动推导(GUI"用户设置"页只需填密码);
# 若你的 course.sjtu.plus 邮箱前缀与 jaccount 用户名不同,取消注释显式指定即可。
# COURSE_PLUS_EMAIL=your_email@sjtu.edu.cn
COURSE_PLUS_PASSWORD=your_course_plus_password

# 邮件通知 (QQ 邮箱示例;Gmail/163 同理,密码用授权码不是登录密码)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=youraddress@qq.com
SMTP_PASS=your_smtp_authorization_code
MAIL_FROM=youraddress@qq.com
MAIL_TO=youraddress@qq.com

# 可选:轮询间隔 (秒),会在 MIN-MAX 之间随机抖动
POLL_MIN=60
POLL_MAX=120
